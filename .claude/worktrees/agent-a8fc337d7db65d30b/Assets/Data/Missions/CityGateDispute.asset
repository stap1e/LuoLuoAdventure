  MissionId: city_gate_dispute
  DisplayName: City Gate Dispute
  Description: Mediate a city-gate standoff while protecting the core, preserving
    the Beast negotiator, and containing extremist raiders.
  RecommendedCommanderLevel: 1
  DefaultObjectives:
  - ObjectiveId: protect_core
    Description: Protect CityGateCore
    IsCompleted: 0
    IsFailed: 0
    Progress: 0
    RequiredProgress: 1
  - ObjectiveId: protect_negotiator
