    Progress: 0
    RequiredProgress: 1
  - ObjectiveId: keep_casualties_low
    Description: Keep casualties low
    IsCompleted: 0
    IsFailed: 0
    Progress: 0
    RequiredProgress: 1
  OutcomeConsequences:
  - Outcome: 5
    CommanderExperienceDelta: 350
    FactionDeltas: []
    SummaryText: Mainstream hostility reduced below 40; extremists remain contained.
  - Outcome: 6
    CommanderExperienceDelta: 250
    FactionDeltas: []
    SummaryText: Mecha order is restored, but Beast trust suffers.
  - Outcome: 7
    CommanderExperienceDelta: 250
    FactionDeltas: []
    SummaryText: Beast hostility drops after negotiation, while Mecha support softens.
  - Outcome: 8
    CommanderExperienceDelta: 30
    FactionDeltas: []
